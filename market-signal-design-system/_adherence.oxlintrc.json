{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/**",
              "ui_kits/market_signal_desktop/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Source Serif 4|Public Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Source Serif 4, Public Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='DirectionalValue'] > JSXAttribute > JSXIdentifier[name!=/^(?:dir|children|size|style|key|ref|className|style|children)$/]",
        "message": "<DirectionalValue> doesn't accept that prop. Declared props: dir, children, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DirectionalValue'] > JSXAttribute[name.name='dir'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<DirectionalValue> dir must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GradeChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|size|style|key|ref|className|style|children)$/]",
        "message": "<GradeChip> doesn't accept that prop. Declared props: value, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GradeChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<GradeChip> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeyFigureItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sans|key|ref|className|style|children)$/]",
        "message": "<KeyFigureItem> doesn't accept that prop. Declared props: label, value, sans."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "DirectionalValue": {
        "replaces": []
      },
      "GradeChip": {
        "replaces": []
      },
      "KeyFigureItem": {
        "replaces": []
      }
    },
    "tokens": [
